APP_NAME=smart-grant
APP_ENV=development
APP_DEBUG=true

SERVER_HTTP_HOST=0.0.0.0
SERVER_HTTP_PORT=8080
SERVER_GRPC_HOST=0.0.0.0
SERVER_GRPC_PORT=9090

GATEWAY_HTTP_HOST=0.0.0.0
GATEWAY_HTTP_PORT=8081

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smart_grant
POSTGRES_SSLMODE=disable

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

OTEL_SERVICE_NAME=smart-grant
OTEL_ENDPOINT=localhost:4317
OTEL_INSECURE=true
OTEL_TRACE_RATIO=0.1

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smart-grant
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
